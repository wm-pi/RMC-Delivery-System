{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @rmc/worker start",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
