# 로컬 worker 환경변수 (선택) — 미설정 시 모두 안전한 기본값으로 동작
# 실제 .env는 git에 커밋되지 않음. Railway 등 배포 시 대시보드 환경변수로 주입.

# JWT 서명 비밀키 (운영 필수)
# JWT_SECRET=change-me-in-production

# 네이버 Directions(길찾기) — 미설정 시 직선거리(haversine)로 ETA 폴백
# NCP 콘솔 Maps Application에서 Directions 15 구독 후, 인증정보의 Key ID/Secret 사용
# NAVER_DIRECTIONS_KEY_ID=your-ncp-key-id
# NAVER_DIRECTIONS_KEY=your-ncp-secret

# 지오펜스 반경(m), 시뮬레이션 배속 등 (기본값 사용 권장)
# GEOFENCE_M=150
# SIM_MULTIPLIER=6
