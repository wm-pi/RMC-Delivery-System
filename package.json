{
  "name": "rmc-delivery-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @rmc/web dev",
    "dev:worker": "pnpm --filter @rmc/worker dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "start:worker": "pnpm --filter @rmc/worker start"
  },
  "engines": {
    "node": ">=22.5"
  },
  "packageManager": "pnpm@10.33.0"
}
